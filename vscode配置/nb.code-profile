{"name":"nb","settings":"{\"settings\":\"{\\n    \\\"workbench.colorTheme\\\": \\\"GitHub Dark Dimmed\\\",\\n    \\\"git.enableSmartCommit\\\": true,\\n    \\\"git.autofetch\\\": true,\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.formatOnPaste\\\": true,\\n    \\\"editor.formatOnType\\\": true,\\n    \\\"C_Cpp.clang_format_fallbackStyle\\\": \\\"WebKit\\\",\\n    \\\"C_Cpp.clang_format_style\\\": \\\"WebKit\\\",\\n    \\\"editor.smoothScrolling\\\": true,\\n    \\\"editor.cursorSmoothCaretAnimation\\\": \\\"on\\\",\\n    \\\"workbench.list.smoothScrolling\\\": true,\\n    \\\"terminal.integrated.smoothScrolling\\\": true,\\n    \\\"editor.cursorBlinking\\\": \\\"smooth\\\",\\n    \\\"trae.enableCodelens\\\": {\\n        \\\"enableInlineDocumentation\\\": false,\\n        \\\"enableInlineExplain\\\": false\\n    },\\n    \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\n    \\\"claudeCode.preferredLocation\\\": \\\"panel\\\",\\n    \\\"editor.aiStats.enabled\\\": true,\\n    \\\"cph-ng.languages.cppCompilerArgs\\\": \\\"-O2 -std=c++17 -Wall -DCPH\\\",\\n    \\\"terminal.integrated.profiles.linux\\\": {\\n        \\\"bash\\\": {\\n            \\\"path\\\": \\\"bash\\\",\\n            \\\"icon\\\": \\\"terminal-bash\\\"\\n        },\\n        \\\"zsh\\\": {\\n            \\\"path\\\": \\\"zsh\\\"\\n        },\\n        \\\"fish\\\": {\\n            \\\"path\\\": \\\"/usr/sbin/fish\\\"\\n        },\\n        \\\"tmux\\\": {\\n            \\\"path\\\": \\\"tmux\\\",\\n            \\\"icon\\\": \\\"terminal-tmux\\\"\\n        },\\n        \\\"pwsh\\\": {\\n            \\\"path\\\": \\\"pwsh\\\",\\n            \\\"icon\\\": \\\"terminal-powershell\\\"\\n        }\\n    },\\n    \\\"terminal.integrated.defaultProfile.linux\\\": \\\"fish\\\",\\n    \\\"geminicodeassist.project\\\": \\\"gemini-wzy-114514\\\",\\n    \\\"github.copilot.nextEditSuggestions.eagerness\\\": \\\"high\\\",\\n    \\\"editor.minimap.size\\\": \\\"fit\\\",\\n    \\\"continue.enableTabAutocomplete\\\": false,\\n    \\\"github.copilot.enable\\\": {\\n        \\\"*\\\": true,\\n        \\\"plaintext\\\": false,\\n        \\\"markdown\\\": false,\\n        \\\"scminput\\\": false,\\n        \\\"cpp\\\": false\\n    },\\n    \\\"editor.fontFamily\\\": \\\"'JetBrains Maple Mono'\\\",\\n    \\\"cph-ng.languages.cppCompiler\\\": \\\"/usr/sbin/g++\\\",\\n    \\\"cph-ng.sidebar.showOobe\\\": false,\\n    \\\"chat.mcp.gallery.enabled\\\": true,\\n    \\\"editor.fontLigatures\\\": true,\\n    \\\"C_Cpp.codeAnalysis.clangTidy.enabled\\\": true,\\n    \\\"claudeCode.disableLoginPrompt\\\": true,\\n    \\\"C_Cpp.autocompleteAddParentheses\\\": true,\\n    \\\"C_Cpp.default.cppStandard\\\": \\\"c++26\\\",\\n    \\\"C_Cpp.default.mergeConfigurations\\\": true,\\n    \\\"files.exclude\\\": {\\n        \\\"**/.git\\\": true,\\n        \\\"**/node_modules\\\": true\\n    },\\n    \\\"C_Cpp.files.exclude\\\": {\\n        \\\"**/.claude\\\": true,\\n        \\\"**/.idea\\\": true,\\n        \\\"**/.cph-ng\\\": true,\\n        \\\"**/.cobridge\\\": true,\\n        \\\"**/.vscode\\\": true,\\n        \\\"**/.git\\\": true,\\n        \\\"**/node_modules\\\": true\\n    },\\n    \\\"C_Cpp.workspaceParsingPriority\\\": \\\"low\\\"\\n}\"}","keybindings":"{\"keybindings\":\"[\\n    // 1. 禁用内置的“添加多光标”命令（命令名前加减号表示移除绑定）\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+down\\\",\\n        \\\"command\\\": \\\"-editor.action.insertCursorBelow\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+up\\\",\\n        \\\"command\\\": \\\"-editor.action.insertCursorAbove\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+left\\\",\\n        \\\"command\\\": \\\"-cursorColumnSelectLeft\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+right\\\",\\n        \\\"command\\\": \\\"-cursorColumnSelectRight\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    // 显式绑定上下键为“向上/下扩展选中”\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+up\\\",\\n        \\\"command\\\": \\\"cursorUpSelect\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+down\\\",\\n        \\\"command\\\": \\\"cursorDownSelect\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    // 确保把旧的“添加光标”命令彻底屏蔽（注意命令 ID 必须精准）\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+up\\\",\\n        \\\"command\\\": \\\"-editor.action.insertCursorAbove\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+down\\\",\\n        \\\"command\\\": \\\"-editor.action.insertCursorBelow\\\",\\n        \\\"when\\\": \\\"editorTextFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+e\\\",\\n        \\\"command\\\": \\\"cph-ng.submit\\\",\\n        \\\"when\\\": \\\"cph-ng.hasProblem\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+alt+s\\\",\\n        \\\"command\\\": \\\"-cph-ng.submit\\\",\\n        \\\"when\\\": \\\"cph-ng.hasProblem\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+a\\\",\\n        \\\"command\\\": \\\"cph-ng.runAllTestcases\\\",\\n        \\\"when\\\": \\\"cph-ng.hasProblem && !cph-ng.isRunning\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+alt+b\\\",\\n        \\\"command\\\": \\\"-cph-ng.runAllTestcases\\\",\\n        \\\"when\\\": \\\"cph-ng.hasProblem && !cph-ng.isRunning\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+b\\\",\\n        \\\"command\\\": \\\"cph-ng.stopTestcases\\\",\\n        \\\"when\\\": \\\"cph-ng.hasProblem && cph-ng.isRunning\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+alt+b\\\",\\n        \\\"command\\\": \\\"-cph-ng.stopTestcases\\\",\\n        \\\"when\\\": \\\"cph-ng.hasProblem && cph-ng.isRunning\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"f5\\\",\\n        \\\"command\\\": \\\"extension.CompileRun\\\",\\n        \\\"when\\\": \\\"editorLangId == 'c' || editorLangId == 'cc' || editorLangId == 'cpp'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+6\\\",\\n        \\\"command\\\": \\\"-extension.CompileRun\\\",\\n        \\\"when\\\": \\\"editorLangId == 'c' || editorLangId == 'cc' || editorLangId == 'cpp'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"f6\\\",\\n        \\\"command\\\": \\\"-extension.CompileRun\\\",\\n        \\\"when\\\": \\\"editorLangId == 'c' || editorLangId == 'cc' || editorLangId == 'cpp'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"f7\\\",\\n        \\\"command\\\": \\\"-extension.CustomCompileRun\\\",\\n        \\\"when\\\": \\\"editorLangId == 'c' || editorLangId == 'cc' || editorLangId == 'cpp'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"f8\\\",\\n        \\\"command\\\": \\\"-extension.CompileRunInExternalTerminal\\\",\\n        \\\"when\\\": \\\"editorLangId == 'c' || editorLangId == 'cc' || editorLangId == 'cpp'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"f5\\\",\\n        \\\"command\\\": \\\"-extension.Debug\\\",\\n        \\\"when\\\": \\\"editorLangId == 'c' || editorLangId == 'cc' || editorLangId == 'cpp'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+enter\\\",\\n        \\\"command\\\": \\\"-workbench.action.chat.applyInEditor\\\",\\n        \\\"when\\\": \\\"accessibleViewInCodeBlock && chatIsEnabled || chatIsEnabled && inChat && !inChatInput\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+a\\\",\\n        \\\"command\\\": \\\"-workbench.action.chat.focusConfirmation\\\",\\n        \\\"when\\\": \\\"accessibilityModeEnabled && chatIsEnabled\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+alt+t\\\",\\n        \\\"command\\\": \\\"-workbench.action.terminal.chat.focusMostRecentChatTerminal\\\",\\n        \\\"when\\\": \\\"inChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+alt+o\\\",\\n        \\\"command\\\": \\\"-workbench.action.terminal.chat.focusMostRecentChatTerminalOutput\\\",\\n        \\\"when\\\"